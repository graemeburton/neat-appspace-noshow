# .env.example
# =====================================================
# Template for environment variables
# Copy this file to .env and replace the placeholder values
# NEVER commit your real .env file to version control
# =====================================================

# ==================== Neat Pulse ====================
NEAT_TENANT_ID=your_neat_tenant_id_here
NEAT_API_KEY=your_neat_api_key_here

# ==================== Appspace =====================
APPSPACE_BASE_URL=https://api.cloud.appspace.com
APPSPACE_SUBJECT_ID=your_subject_id_here
APPSPACE_REFRESH_TOKEN=your_refresh_token_here

# ==================== Room Mapping (JSON) ==========
# Format: {"appspace_resource_id": "neat_room_id", ...}
# How to get IDs:
#   • Appspace → Admin → Resources → click room → copy "Resource ID"
#   • Neat     → Pulse dashboard → Rooms → click room → copy Room ID
RESOURCE_TO_ROOM_MAP={"appspace-resource-uuid-12345678-90ab-cdef-ghij-klmnopqrstuv":"neat-room-uuid-abcdef12-3456-7890-abcd-ef1234567890"}

# ==================== Optional Settings ============
# Your local timezone (default is Melbourne)
# TIMEZONE=Australia/Melbourne

# How many minutes after meeting start to check for no-show
# CHECK_WINDOW_MINUTES=5